#!/usr/bin/env bash
set -euo pipefail

OUT_DIR="./static"
BASE_URL="http://127.0.0.1:8000"

rm -rf "$OUT_DIR"
mkdir -p "$OUT_DIR"

echo "-- Building static site..."
wget \
  --no-verbose \
  --execute robots=off \
  --recursive \
  --no-parent \
  --level=inf \
  --page-requisites \
  --adjust-extension \
  --no-host-directories \
  --directory-prefix="$OUT_DIR" \
  "$BASE_URL/" 2>&1 | sed 's/^/   /'

echo "-- Successfully exported site to $OUT_DIR"
